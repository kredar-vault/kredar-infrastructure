# Rendered runtime env files (contain decrypted secrets) — never commit.
env/*.runtime.env
env/*.runtime.env.deployed*

# Secret templates you fill in locally (pushed to GitHub secrets, never committed).
secrets/*.env
.env
*.local

# Terraform state (contains secrets - never commit)
*.tfstate
*.tfstate.backup
.terraform/
.terraform.lock.hcl

# Tfvars contain real values - keep out of git
terraform.tfvars
!terraform.tfvars.example

# macOS
.DS_Store
Thumbs.db
