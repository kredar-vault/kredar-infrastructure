# ============================================================================
# STAGING (non-secret) configuration.
# Layer order at render time:  common.env.example -> staging.env.example
#                              -> versions/staging.env -> GitHub secrets
# This file is committed; the deploy renders the real runtime file from these
# layers plus the secrets injected by the GitHub Actions job.
# ============================================================================

ENVIRONMENT=staging

# --- Domains -----------------------------------------------------------------
# A record for the API host points at the staging Elastic IP (terraform output).
DOMAIN=kredar.xyz
KREDAR_API_HOST=api.staging.kredar.xyz
KREDAR_FRONTEND_HOST=staging.kredar.xyz

# --- TLS ---------------------------------------------------------------------
# Let's Encrypt contact email (fill in).
ACME_EMAIL=jeffreyliaison@gmail.com

# --- App runtime -------------------------------------------------------------
KREDAR_ASPNETCORE_ENVIRONMENT=Staging

# CORS origins allowed to call the API (comma-separated). Add the frontend
# origin once the frontend is deployed (e.g. https://staging.kredar.xyz).
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://staging.kredar.xyz

# ============================================================================
# SECRETS (NOT stored here) — set as GitHub Environment secrets on the
# "staging" environment of the kredar-infrastructure repo. The deploy job
# injects them into render-env.sh:
#
#   POSTGRES_PASSWORD        (database password for the kredar_app user)
#   GHCR_USER                (bot/user that can read GHCR packages)
#   GHCR_TOKEN               (read:packages token)
#   TRAEFIK_DASHBOARD_AUTH   (htpasswd "user:hash"; staging only, optional)
#   JWT_SIGNING_KEY          (REQUIRED; >= 32 bytes, unique per env)
#   RESEND_API_KEY           (transactional email; optional until email is used)
#   NOMBA_CLIENT_ID / NOMBA_CLIENT_SECRET / NOMBA_ACCOUNT_ID / NOMBA_SUB_ACCOUNT_ID / NOMBA_WEBHOOK_SECRET   (required for DVA)
#
# Also set as Environment-level VARIABLES (not secrets): SSH_HOST, SSH_USER.
# And the Environment secret SSH_PRIVATE_KEY for the deploy SSH connection.
# ============================================================================
