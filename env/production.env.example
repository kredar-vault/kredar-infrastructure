# ============================================================================
# PRODUCTION (non-secret) configuration.
# Layer order at render time:  common.env.example -> production.env.example
#                              -> versions/production.env -> GitHub secrets
# ============================================================================

ENVIRONMENT=production

# --- Domains -----------------------------------------------------------------
# A record for the API host points at the production Elastic IP (terraform output).
DOMAIN=kredar.xyz
KREDAR_API_HOST=api.kredar.xyz
KREDAR_FRONTEND_HOST=kredar.xyz

# --- TLS ---------------------------------------------------------------------
ACME_EMAIL=ukemeetim2222@gmail.com

# --- App runtime -------------------------------------------------------------
KREDAR_ASPNETCORE_ENVIRONMENT=Production

# CORS origins allowed to call the API (comma-separated). Add the frontend
# origin once the frontend is deployed (e.g. https://kredar.xyz).
CORS_ALLOWED_ORIGINS=https://kredar.xyz

# --- Nomba (live production credentials) -------------------------------------
NOMBA_BASE_URL=https://api.nomba.com/v1

# ============================================================================
# SECRETS (NOT stored here) — set as GitHub Environment secrets on the
# "production" environment of the kredar-infrastructure repo:
#
#   POSTGRES_PASSWORD        (database password for the kredar_app user)
#   GHCR_USER
#   GHCR_TOKEN
#   JWT_SIGNING_KEY          (REQUIRED; >= 32 bytes, DIFFERENT from staging)
#   RESEND_API_KEY           (transactional email)
#   NOMBA_CLIENT_ID / NOMBA_CLIENT_SECRET / NOMBA_ACCOUNT_ID   (LIVE creds)
#
# Plus Environment VARIABLES SSH_HOST, SSH_USER and the Environment secret
# SSH_PRIVATE_KEY. The Traefik dashboard is disabled in production.
# ============================================================================

# AjoVault subdomains (A records -> production Elastic IP)
AJOVAULT_FRONTEND_HOST=vault.kredar.xyz
AJOVAULT_API_HOST=api.vault.kredar.xyz
AJOVAULT_ASPNETCORE_ENVIRONMENT=Production
