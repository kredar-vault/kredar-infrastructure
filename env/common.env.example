# ============================================================================
# COMMON (non-secret) defaults shared by every environment.
# Copied as the first layer when rendering a runtime env file.
# Real secrets never live here — they come from GitHub Environment secrets.
# ============================================================================

# Pinned infrastructure image versions (overridable per env).
TRAEFIK_IMAGE=traefik:v3.6
POSTGRES_IMAGE=postgres:17-alpine

# Database name + app user (not secret; the password comes from a GitHub secret).
POSTGRES_USER=kredar_app
POSTGRES_DB=kredar

# ---- Kredar backend app config (non-secret) --------------------------------
# JWT issuer/audience (the signing key itself is a GitHub secret: JWT_SIGNING_KEY).
JWT_ISSUER=kredar-api
JWT_AUDIENCE=kredar-clients
JWT_EXPIRY_MINUTES=60

# Transactional email sender (the Resend API key is a secret: RESEND_API_KEY).
# The domain must be verified in Resend before sends succeed.
RESEND_FROM_EMAIL=no-reply@kredar.xyz
RESEND_FROM_NAME=Kredar

NOMBA_WEBHOOK_SIGNATURE_HEADER=nomba-signature
NOMBA_TIMESTAMP_HEADER=nomba-timestamp
NOMBA_TOKEN_REFRESH_SECONDS=3300
