# Copy to terraform.tfvars and fill in. terraform.tfvars is git-ignored.
aws_region      = "eu-west-1"
instance_type   = "t3.small"

# Ubuntu 24.04 LTS AMI for your region (AWS console → AMI catalog → Ubuntu 24.04).
ami_id          = "ami-xxxxxxxxxxxxxxxxx"

# The deploy key's PUBLIC half (generate: ssh-keygen -t ed25519 -f ~/.ssh/kredar_deploy).
public_key_path = "~/.ssh/kredar_deploy.pub"

# Optional hardening: narrow SSH to a known network, e.g. "203.0.113.4/32".
ssh_ingress_cidr = "0.0.0.0/0"
